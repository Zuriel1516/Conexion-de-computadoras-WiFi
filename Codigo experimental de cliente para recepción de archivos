import socket
import hashlib
import os

HOST = "0.0.0.0"
PORT = 6000

server = socket.socket()
server.bind((HOST, PORT))
server.listen(1)

print("Servidor de archivos esperando conexión...")

conn, addr = server.accept()
print("Conectado con:", addr)

# Recibir encabezado
header = conn.recv(1024).decode()
nombre, tamaño, hash_cliente = header.split("|")
tamaño = int(tamaño)

print("Archivo:", nombre)
print("Tamaño:", tamaño)

